---
import FileTreeItem from "./FileTreeItem.astro";
import { parseFileTree } from "./parseFileTree";
import type { FileTreeNode } from "./parseFileTree";

type ItemProps = FileTreeNode & Record<string, unknown>;

const {
  mode = "structured",
  items = [] as ItemProps[],
  source = "",
  class: className,
  useDefaultEditableBinding = false,
  "data-children-prop": childrenDataProp,
  _component,
  ...htmlAttributes
} = Astro.props;

const resolvedMode = mode === "raw" ? "raw" : "structured";

const effectiveChildrenProp =
  childrenDataProp ?? (useDefaultEditableBinding ? "items" : null);
const arrayDataAttributes =
  resolvedMode === "structured" && effectiveChildrenProp
    ? { "data-editable": "array", "data-prop": effectiveChildrenProp }
    : {};

const parsedItems: ItemProps[] =
  resolvedMode === "raw" ? (parseFileTree(source) as ItemProps[]) : (items as ItemProps[]);

const hasItems = parsedItems?.length > 0;
const hasSlotContent = Astro.slots.has("default");

if (!_component && !hasItems && !hasSlotContent) return;
---

<div
  class:list={["file-tree", className]}
  {...htmlAttributes}
>
  <ul
    class="file-tree-list"
    role="tree"
    {...arrayDataAttributes}
  >
    <slot>
      {
        parsedItems?.map((item: ItemProps) => (
          <FileTreeItem
            useDefaultEditableBinding={resolvedMode === "structured" && !!effectiveChildrenProp}
            data-editable={resolvedMode === "structured" ? "array-item" : undefined}
            data-id="building-blocks/wrappers/file-tree/file-tree-item"
            {...item}
          />
        ))
      }
    </slot>
  </ul>
</div>

<style>
  @layer components {
    .file-tree {
      background-color: var(--color-bg-surface);
      border: 1px solid var(--color-border-subtle);
      border-radius: var(--radius-sm);
      font-family: var(--font-family-mono, "JetBrains Mono", "Fira Code", monospace);
      font-size: var(--font-size-sm);
      margin-top: var(--spacing-lg);
      overflow-x: auto;
      padding: var(--spacing-sm) var(--spacing-md);

      > .file-tree-list {
        list-style: none;
        margin: 0;
        padding: 0;
      }
    }
  }
</style>
