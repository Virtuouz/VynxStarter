---
import Heading from "@core-elements/heading/Heading.astro";
import Image from "@core-elements/image/Image.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import Text from "@core-elements/text/Text.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";

const {
  index = 1,
  isLast = false,
  eyebrow = "",
  title = "",
  description = "",
  imageSource = "",
  imageAlt = "",
  buttonSections = [],
  class: className,
  useDefaultEditableBinding: _useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;

const paddedIndex = String(index).padStart(2, "0");
const reverse = index % 2 === 0;
---

<li
  class:list={["timeline-phase", reverse && "timeline-phase--reverse", className]}
  {...htmlAttributes}
>
  <div class="timeline-phase__rail" aria-hidden="true">
    <div class="timeline-phase__node">
      <span class="timeline-phase__node-dot"></span>
    </div>
    {!isLast && <div class="timeline-phase__line"></div>}
  </div>

  <div class="timeline-phase__content">
    <span class="timeline-phase__index" aria-hidden="true">{paddedIndex}</span>
    <SimpleText
      class="timeline-phase__eyebrow"
      data-prop="eyebrow"
      text={eyebrow}
    />
    <Heading
      level="h3"
      size="xl"
      class="timeline-phase__title"
      data-prop="title"
    >
      {title}
    </Heading>
    <Text
      class="timeline-phase__description"
      data-prop="description"
      text={description}
    />
    <ButtonGroup
      class="timeline-phase__buttons"
      buttonSections={buttonSections}
      data-children-prop="buttonSections"
    />
  </div>

  <div class="timeline-phase__media">
    <div class="timeline-phase__media-frame">
      <Image
        source={imageSource}
        alt={imageAlt}
        class="timeline-phase__image"
        data-prop-src="imageSource"
        data-prop-alt="imageAlt"
      />
    </div>
  </div>
</li>

<style>
  @layer page-sections {
    .timeline-phase {
      align-items: start;
      container-type: inline-size;
      display: grid;
      gap: var(--spacing-xl);
      grid-template-columns: 48px 1fr 1fr;
      position: relative;
    }

    .timeline-phase--reverse .timeline-phase__content {
      grid-column: 3;
      grid-row: 1;
    }

    .timeline-phase--reverse .timeline-phase__media {
      grid-column: 2;
      grid-row: 1;
    }

    .timeline-phase__rail {
      display: flex;
      flex-direction: column;
      grid-column: 1;
      grid-row: 1;
      height: 100%;
      position: relative;
    }

    .timeline-phase__node {
      align-items: center;
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      border-radius: 50%;
      display: flex;
      height: 36px;
      justify-content: center;
      margin-top: 8px;
      position: relative;
      width: 36px;
      z-index: 1;
    }

    .timeline-phase__node-dot {
      background: var(--color-brand);
      border-radius: 50%;
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--color-brand) 18%, transparent);
      height: 10px;
      width: 10px;
    }

    .timeline-phase__line {
      background: linear-gradient(
        to bottom,
        var(--color-border) 0%,
        color-mix(in srgb, var(--color-border) 0%, transparent) 100%
      );
      flex: 1;
      margin-top: var(--spacing-xs);
      width: 1px;
    }

    .timeline-phase__content {
      grid-column: 2;
      grid-row: 1;
      min-width: 0;
    }

    .timeline-phase__index {
      color: var(--color-text-muted);
      display: block;
      font-family: "SFMono-Regular", ui-monospace, Menlo, Monaco, Consolas, monospace;
      font-size: var(--font-size-sm);
      letter-spacing: 0.1em;
      opacity: 0.6;
    }

    :global(.timeline-phase__eyebrow) {
      margin-top: var(--spacing-xs);
    }

    :global(.timeline-phase__eyebrow .simple-text-content) {
      color: var(--color-brand);
      font-family: "SFMono-Regular", ui-monospace, Menlo, Monaco, Consolas, monospace;
      font-size: var(--font-size-xs);
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    :global(.timeline-phase__title) {
      letter-spacing: -0.01em;
      margin-top: var(--spacing-sm);
    }

    :global(.timeline-phase__description p) {
      color: var(--color-text-muted);
      line-height: 1.65;
    }

    :global(.timeline-phase__description strong) {
      color: var(--color-text-strong);
      font-weight: 600;
    }

    :global(.timeline-phase__buttons) {
      margin-top: var(--spacing-lg);
    }

    .timeline-phase__media {
      grid-column: 3;
      grid-row: 1;
      min-width: 0;
    }

    .timeline-phase__media-frame {
      background: var(--color-bg-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      box-shadow: 0 20px 60px -20px color-mix(in srgb, var(--color-brand) 25%, transparent);
      overflow: hidden;
      padding: var(--spacing-sm);
      position: relative;
    }

    .timeline-phase__media-frame::before {
      background: linear-gradient(
        135deg,
        color-mix(in srgb, var(--color-brand) 30%, transparent) 0%,
        transparent 60%
      );
      content: "";
      inset: 0;
      opacity: 0.4;
      pointer-events: none;
      position: absolute;
    }

    :global(.timeline-phase__image) {
      margin-top: 0;
      position: relative;
      z-index: 1;
    }

    :global(.timeline-phase__image .image-inner) {
      border-radius: var(--radius-md);
    }

    @container (max-width: 720px) {
      .timeline-phase {
        grid-template-columns: 40px 1fr;
      }

      .timeline-phase__media {
        grid-column: 2;
        grid-row: 2;
        margin-top: var(--spacing-lg);
      }

      .timeline-phase--reverse .timeline-phase__content,
      .timeline-phase__content {
        grid-column: 2;
        grid-row: 1;
      }

      .timeline-phase--reverse .timeline-phase__media {
        grid-column: 2;
        grid-row: 2;
      }
    }
  }
</style>
