---
import Page from "@layouts/Page.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

export interface Props {
  page: CollectionEntry<"pages">;
}

export async function getStaticPaths() {
  const { slugifyLabel } = await import("@components/utils/slugify");
  const pages = await getCollection("pages");

  return pages
    .filter((page) => page.id !== "blog" && !page.data.draft)
    .map((page) => {
      const segments = page.id.split("/");
      const last = segments[segments.length - 1];
      const folder = segments.slice(0, -1).join("/");

      let slug: string;
      if (last === "index") {
        slug = folder;
      } else {
        const raw = page.data.pageLink?.trim() || page.data.title;
        const leaf = slugifyLabel(raw);
        slug = folder ? `${folder}/${leaf}` : leaf;
      }

      if (slug.length === 0) return { params: { slug: undefined }, props: { page } };
      return { params: { slug }, props: { page } };
    });
}

const { page } = Astro.props;
const { Content } = await render(page);
---

<Page frontmatter={page.data}>
  <Content />
</Page>
