---
import { readFileSync } from "fs";
import CollectionItem from "@layouts/CollectionItem.astro";
import { getCollection, render } from "astro:content";

interface CollectionDef {
  name: string;
  slug: string;
  enabled: boolean;
  singular_label: string;
  has_archive: boolean;
  archive_url?: string;
  fields: { key: string; type: string; required?: boolean }[];
}

interface CollectionsConfig {
  collections: CollectionDef[];
}

export async function getStaticPaths() {
  const raw = readFileSync("./src/data/collections.json", "utf-8");
  const config = JSON.parse(raw) as CollectionsConfig;

  if (!config?.collections?.length) return [];

  const paths = [];

  for (const col of config.collections) {
    if (!col.enabled) continue;

    let items: any[] = [];
    try {
      items = await getCollection(col.slug);
    } catch {
      continue;
    }

    for (const item of items) {
      const slug = item.id?.replace(/\.md$/, "") || item.slug;
      paths.push({
        params: { collection: col.slug, slug },
        props: { item, collectionDef: col },
      });
    }
  }

  return paths;
}

interface Props {
  item: any;
  collectionDef: CollectionDef;
}

const { item, collectionDef } = Astro.props;
const { Content } = await render(item);
---

<CollectionItem
  title={item.data.title || ""}
  description={item.data.description}
  image={item.data.image}
  collectionName={collectionDef.name}
  collectionSlug={collectionDef.slug}
  singularLabel={collectionDef.singular_label}
>
  <Content />
</CollectionItem>
